{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StageCanvas Messages v1",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/Heartbeat" },
    { "$ref": "#/$defs/ControlCommand" },
    { "$ref": "#/$defs/StateUpdate" }
  ],
  "$defs": {
    "BaseMessage": {
      "type": "object",
      "properties": {
        "version": { "type": "string", "const": "v1" },
        "message_id": { "type": "string" },
        "timestamp_ms": { "type": "integer", "minimum": 0 },
        "node_id": { "type": "string" }
      },
      "required": ["version", "message_id", "timestamp_ms", "node_id"],
      "additionalProperties": true
    },
    "Heartbeat": {
      "allOf": [
        { "$ref": "#/$defs/BaseMessage" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "HEARTBEAT" },
            "status": { "enum": ["IDLE", "LOADING", "READY", "PLAYING", "PAUSED", "ERROR"] },
            "show_id": { "type": ["string", "null"] },
            "position_ms": { "type": "integer", "minimum": 0 },
            "drift_ms": { "type": "number" },
            "metrics": {
              "type": "object",
              "properties": {
                "cpu_pct": { "type": "number" },
                "gpu_pct": { "type": "number" },
                "fps": { "type": "number" },
                "dropped_frames": { "type": "integer", "minimum": 0 }
              },
              "required": ["cpu_pct", "gpu_pct", "fps", "dropped_frames"]
            }
          },
          "required": ["type", "status", "metrics", "position_ms", "drift_ms"]
        }
      ]
    },
    "ControlCommand": {
      "allOf": [
        { "$ref": "#/$defs/BaseMessage" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "COMMAND" },
            "command": { "enum": ["LOAD_SHOW", "PLAY_AT", "PAUSE", "SEEK", "STOP", "PING", "PLAY_CLIP"] },
            "target_time_ms": { "type": "integer", "minimum": 0 },
            "payload": {
              "type": "object",
              "properties": {
                "mapping_config": { "$ref": "#/$defs/MappingConfig" }
              },
              "additionalProperties": true
            },
            "seq": { "type": "integer", "minimum": 0 }
          },
          "required": ["type", "command", "seq"]
        }
      ]
    },
    "StateUpdate": {
      "allOf": [
        { "$ref": "#/$defs/BaseMessage" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "STATE_UPDATE" },
            "show_id": { "type": "string" },
            "status": { "enum": ["IDLE", "LOADING", "READY", "PLAYING", "PAUSED", "ERROR"] },
            "position_ms": { "type": "integer", "minimum": 0 },
            "drift_ms": { "type": "number" },
            "drift_level": { "enum": ["OK", "WARN", "CRITICAL"] }
          },
          "required": ["type", "show_id", "status", "position_ms", "drift_ms", "drift_level"]
        }
      ]
    },
    "MappingBlend": {
      "type": "object",
      "properties": {
        "gamma": { "type": "number", "minimum": 0 },
        "brightness": { "type": "number", "minimum": 0 },
        "black_level": { "type": "number", "minimum": 0 }
      },
      "required": [],
      "additionalProperties": false
    },
    "MappingMesh": {
      "type": "object",
      "properties": {
        "vertices": { "type": "array", "items": { "type": "number" }, "minItems": 6 },
        "uvs": { "type": "array", "items": { "type": "number" }, "minItems": 6 },
        "indices": { "type": "array", "items": { "type": "integer" }, "minItems": 3 }
      },
      "required": ["vertices", "uvs", "indices"],
      "additionalProperties": false
    },
    "MappingOutput": {
      "type": "object",
      "properties": {
        "output_id": { "type": "string" },
        "mesh": { "$ref": "#/$defs/MappingMesh" },
        "blend": { "$ref": "#/$defs/MappingBlend" }
      },
      "required": ["output_id", "mesh"],
      "additionalProperties": false
    },
    "MappingConfig": {
      "type": "object",
      "properties": {
        "version": { "type": "string", "const": "v1" },
        "outputs": { "type": "array", "items": { "$ref": "#/$defs/MappingOutput" }, "minItems": 1 }
      },
      "required": ["version", "outputs"],
      "additionalProperties": false
    },
    "MediaCodecProfile": {
      "type": "string",
      "enum": ["HAP", "HAP-Q", "ProRes4444", "H264", "H265"]
    },
    "MediaAssetMetadata": {
      "type": "object",
      "properties": {
        "codec_profile": { "$ref": "#/$defs/MediaCodecProfile" },
        "duration_ms": { "type": "integer", "minimum": 0 },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "checksum": { "type": ["string", "null"] },
        "uri": { "type": ["string", "null"] }
      },
      "required": ["codec_profile", "duration_ms", "size_bytes"],
      "additionalProperties": true
    },
    "TimelineLayer": {
      "type": "object",
      "properties": {
        "layer_id": { "type": "string" },
        "label": { "type": "string" },
        "asset_id": { "type": ["string", "null"] },
        "opacity": { "type": "number", "minimum": 0, "maximum": 1.0, "default": 1.0 },
        "blend_mode": { "enum": ["normal", "add", "multiply", "screen"], "default": "normal" },
        "transform": {
          "type": "object",
          "properties": {
            "x": { "type": "number", "default": 0 },
            "y": { "type": "number", "default": 0 },
            "scale_x": { "type": "number", "default": 1 },
            "scale_y": { "type": "number", "default": 1 }
          }
        }
      },
      "required": ["layer_id", "label"]
    },
    "TimelineClip": {
      "type": "object",
      "properties": {
        "clip_id": { "type": "string" },
        "label": { "type": "string" },
        "start_ms": { "type": "integer", "minimum": 0 },
        "duration_ms": { "type": "integer", "minimum": 1 },
        "offset_ms": { "type": "integer", "default": 0 },
        "kind": { "enum": ["video", "audio", "image", "alpha", "trigger"] },
        "layers": {
          "type": "array",
          "items": { "$ref": "#/$defs/TimelineLayer" }
        }
      },
      "required": ["clip_id", "label", "start_ms", "duration_ms"]
    },
    "TimelineTrack": {
      "type": "object",
      "properties": {
        "track_id": { "type": "string" },
        "label": { "type": "string" },
        "kind": { "enum": ["video", "audio", "image", "alpha", "trigger"] },
        "clips": {
          "type": "array",
          "items": { "$ref": "#/$defs/TimelineClip" }
        }
      },
      "required": ["track_id", "label"]
    }
  }
}
